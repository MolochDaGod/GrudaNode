{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install",
  "builds": [
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/favicon.ico", "dest": "server.js" },
    { "src": "/favicon.svg", "dest": "server.js" },
    { "src": "/apple-touch-icon.png", "dest": "server.js" },
    { "src": "/(.*)", "dest": "server.js" }
  ],
  "env": {
    "NODE_ENV": "production",
    "VERCEL": "1",
    "GRUDGE_SOCIAL_URL": "https://grudge-social.puter.site",
    "GRUDGE_AI_HUB_URL": "https://ai.grudge-studio.com"
  }
}