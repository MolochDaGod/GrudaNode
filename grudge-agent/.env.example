# ── GRUDA Agent Config ─────────────────────────────────────────
PORT=3200

# ── Ollama ─────────────────────────────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
DEFAULT_MODEL=mistral:latest

# ── Local data dirs (desktop best practices) ───────────────────
# Windows defaults:
#   DATA_DIR     → %APPDATA%\GrudgeStudio\gruda-agent
#   PROJECTS_DIR → %LOCALAPPDATA%\GrudgeStudio\gruda-agent\projects
# macOS: ~/Library/Application Support/GrudgeStudio/gruda-agent
# Linux:  ~/.config/gruda-agent  and  ~/.local/share/gruda-agent/projects
DATA_DIR=
PROJECTS_DIR=

# ── Splash GIFs (shown on startup) ────────────────────────────
# Full paths to your intro GIFs — leave blank to skip
SPLASH_GIF_1=C:\Users\david\OneDrive\Desktop\MouseWithoutBorders\grudgestudio.gif
SPLASH_GIF_2=C:\Users\david\OneDrive\Desktop\MouseWithoutBorders\hts.gif

# ── Grok / xAI (cloud Agent mode on Vercel) ───────────────────
# Required for tool-using Agent mode when Ollama is unavailable.
# https://console.x.ai/
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1

# ── Web Search (optional) ──────────────────────────────────────
# Leave blank to use DuckDuckGo (no key needed, limited results)
# Or add a Brave Search API key for richer results (free tier: 2000/mo)
# https://brave.com/search/api/
BRAVE_SEARCH_KEY=

# ── Music generation — Mureka (optional) ──────────────────────
# Get a key at https://platform.mureka.ai (Dashboard → API Keys)
MUREKA_API_KEY=
# Default Mureka model: auto | mureka-6 | mureka-7.5 | mureka-o1
MUREKA_MODEL=auto

# ── Voice — ElevenLabs TTS (optional) ────────────────────────
# Leave blank to use the browser's built-in speech synthesis instead.
# https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=
# Optional default voice id (otherwise a sensible default is used)
ELEVENLABS_VOICE_ID=

# ── Assets (optional) ─────────────────────────────────
# Poly Pizza API key for the Assets browser (Poly Haven works without a key)
# https://poly.pizza/api
POLY_PIZZA_KEY=

# ── Grudge R2 / asset CDN (optional; sensible defaults) ───────
# Source for the Assets tab "Grudge Studio" list and the Environment tab's
# CORS-safe /api/r2/* model loader. Defaults shown.
GRUDGE_R2_CDN=https://assets.grudge-studio.com
GRUDGE_ASSET_API=https://api.grudge-studio.com

# ── Grudge AI Hub (cloud Gemini — works without Ollama on Linux) ──
GRUDGE_AI_HUB_URL=https://ai.grudge-studio.com
# Legion hub API key (same as INTERNAL_API_KEY for studio fleet)
GRUDGE_AI_KEY=
LEGION_HUB_API_KEY=

# ── Grudge identity / SSO (optional) ────────────────────────
# The login signs in with Puter and links that Puter ID to a Grudge ID.
# If GRUDGE_ACCOUNT_URL is set, the app POSTs {puterUuid,username} to
# <accountUrl>/link/puter to mint/link the canonical Grudge ID; otherwise a
# deterministic guest Grudge ID is derived locally. An existing session/token
# (Puter session, or ?grudge_token= handed off from another Grudge site) is
# honored without re-prompting.
GRUDGE_AUTH_URL=https://id.grudge-studio.com
GRUDGE_ACCOUNT_URL=

# ── Database (optional) ────────────────────────────────────────
# Set a Postgres URL to persist session history; falls back to local JSON when blank
DATABASE_URL=

# ── Master Node (optional, connects to GrudaChain) ─────────────
MASTER_NODE_URL=http://127.0.0.1:9017
GRUDGE_NEXUS_URL=https://grudachain.grudge-studio.com

# ── Treaty Chat (account-linked rooms via grudge-social worker) ──
GRUDGE_SOCIAL_URL=https://grudge-social.puter.site

# ── AnythingLLM (local RAG — fleet mismatch, game data, telegram) ──
# Run desktop AnythingLLM on :3001; API docs at http://localhost:3001/api/docs
ANYTHINGLLM_BASE_URL=http://localhost:3001/api
ANYTHINGLLM_API_KEY=
ANYTHINGLLM_DEFAULT_WORKSPACE=grudge-fleet

# ── Cloud integrations (stored in ~/.gruda-agent/config.json after connecting via UI)
# GITHUB_TOKEN=ghp_your_token_here
# VERCEL_TOKEN=your_vercel_token
# GOOGLE_CLIENT_ID=your_google_oauth_client_id
# Puter auth is handled entirely in the browser via puter.js — no config needed
