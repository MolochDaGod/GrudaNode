# ── GRUDA Agent Config ─────────────────────────────────────────
PORT=3200

# ── Ollama ─────────────────────────────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
DEFAULT_MODEL=mistral:latest

# ── Projects ───────────────────────────────────────────────────
# Where project folders and gruda.md memory files are stored
# Defaults to ~/gruda-projects
PROJECTS_DIR=

# ── Splash GIFs (shown on startup) ────────────────────────────
# Full paths to your intro GIFs — leave blank to skip
SPLASH_GIF_1=C:\Users\david\OneDrive\Desktop\MouseWithoutBorders\grudgestudio.gif
SPLASH_GIF_2=C:\Users\david\OneDrive\Desktop\MouseWithoutBorders\hts.gif

# ── Web Search (optional) ──────────────────────────────────────
# Leave blank to use DuckDuckGo (no key needed, limited results)
# Or add a Brave Search API key for richer results (free tier: 2000/mo)
# https://brave.com/search/api/
BRAVE_SEARCH_KEY=

# ── Master Node (optional, connects to GrudaChain) ─────────────
MASTER_NODE_URL=http://127.0.0.1:9017

# ── Cloud integrations (stored in ~/.gruda-agent/config.json after connecting via UI)
# GITHUB_TOKEN=ghp_your_token_here
# VERCEL_TOKEN=your_vercel_token
# GOOGLE_CLIENT_ID=your_google_oauth_client_id
# Puter auth is handled entirely in the browser via puter.js — no config needed
