# grudgedot — Environment Variables
# Copy to .env and fill in values. NEVER commit .env

# GitHub App (from https://github.com/settings/apps)
GH_APP_ID=
GH_CLIENT_ID=
GH_SECRET=

# GitHub PAT with read:org, read:packages (fallback when no user token)
GITHUB_TOKEN=

# Your GitHub org/user that owns the game repos
GH_ORG=MolochDaGod

# OAuth callback (update to prod URL before deploying)
CALLBACK_URL=http://localhost:3300/auth/callback

# Server port
PORT=3300
